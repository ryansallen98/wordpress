{
  "name": "theme",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint": "npm run lint:eslint && npm run format:check",
    "lint:fix": "npm run lint:eslint:fix && npm run format",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sage.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/sage.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang"
  },
  "devDependencies": {
    "@alpinejs/collapse": "^3.15.8",
    "@alpinejs/focus": "^3.15.8",
    "@eslint/js": "^10.0.1",
    "@roots/vite-plugin": "^1.0.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.9",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__collapse": "^3.13.4",
    "@types/alpinejs__focus": "^3.13.4",
    "@types/wordpress__dom-ready": "^2.3.0",
    "alpinejs": "^3.15.8",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "laravel-vite-plugin": "^1.2.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "^4.0.9",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.2.0",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
