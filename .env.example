# When using the Docker/Coolify image, DB_* / DATABASE_URL can be omitted and are
# generated on first boot for the bundled MariaDB. To use an external database,
# set DATABASE_URL or DB_HOST (non-127.0.0.1 / non-localhost), plus credentials —
# the entrypoint skips embedded MariaDB and passes these through to Bedrock.
# For non-container local installs, keep real DB values here.
DB_NAME='database_name'
DB_USER='database_user'
DB_PASSWORD='database_password'

# Optionally, you can use a data source name (DSN)
# When using a DSN, you can remove the DB_NAME, DB_USER, DB_PASSWORD, and DB_HOST variables
# DATABASE_URL='mysql://database_user:database_password@database_host:database_port/database_name'

# Optional database variables
# DB_HOST='localhost'
# DB_PREFIX='wp_'

# Coolify can inject WP_ENV at runtime. Local default stays development.
# WP_ENV='production'
WP_ENV='development'

# Docker dev override (`npm run docker:dev`) bind-mounts this file into the app
# and runs Vite HMR in a separate container on VITE_PORT (default 5173).
# VITE_PORT='5173'

# Coolify should inject WP_DOMAIN. WP_SITEURL defaults to "${WP_HOME}/wp" when omitted.
WP_DOMAIN='example.com'
WP_HOME="http://${WP_DOMAIN}"
WP_SITEURL="${WP_HOME}/wp"

# Specify optional debug.log path
# WP_DEBUG_LOG='/path/to/debug.log'

# When using the Docker/Coolify image, salts are generated on first boot if
# these are missing. For non-container installs, generate your keys here:
# https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'

# ------------------------------------------------------------------------------
# Composer — premium plugins (keep secrets in `.env`; do not commit real values)
#
# ACF Pro uses COMPOSER_AUTH (JSON). Do not hand-edit JSON in .env — use the
# variables below; they are turned into valid JSON by:
#   php scripts/composer/export-composer-auth.php
#
# Local (after vendor/ exists, Dotenv loads .env automatically):
#   export COMPOSER_AUTH="$(php scripts/composer/export-composer-auth.php)"
#   composer install
#
# First clone without vendor/: set the two vars in the shell, run the same
# export line, or use a root auth.json from My Account → Licenses (gitignored).
#
# Coolify / `docker compose build`: same variable names as Docker build args
# (compose.yml → Dockerfile php_vendor). Put real values in `.env` at the repo root;
# Compose substitutes them into the build — the file is not required inside the image.
# Minimum for ACFE Pro: ACFE_PRO_KEY + WP_DOMAIN (or explicit ACFE_PRO_URL).
# ACF Pro: ACF_PRO_LICENSE_KEY + WP_HOME (or WP_DOMAIN only; build uses https://{WP_DOMAIN}).
#
# --- ACF Pro (wpengine/advanced-custom-fields-pro) ---
# License key + site URL registered on that license (must match ACF dashboard).
ACF_PRO_LICENSE_KEY='YOUR_ACF_LICENSE_KEY'
# Optional: use a root auth.json instead (gitignored); skip COMPOSER_AUTH export.
#
# --- ACF Extended Pro (junaidbhura/acf-extended-pro) ---
# Activate this hostname on your ACFE license. Hostname only — no https://
ACFE_PRO_KEY='your_acfe_license_key'
ACFE_PRO_URL="${WP_DOMAIN}"


# ------------------------------------------------------------------------------
# MCP (Cursor + Claude Code) — optional API keys for project `.mcp.json` /
# `.cursor/mcp.json`. WordPress does not read these; they are documentation
# placeholders. Set real values in `.env` if your workflow loads `.env` into
# the IDE/terminal environment, or export them in `~/.zshrc` / MCP server UI.
# ------------------------------------------------------------------------------
# CONTEXT7_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# PERPLEXITY_API_KEY=